# ═══════════════════════════════════════════════
# PomodoroNative Monorepo — .gitignore
# 适用: legacy-android / jetpack-android / native-android / flutter_module
# ═══════════════════════════════════════════════

# ─── Gradle 构建产物（所有 Android 项目通用）───
**/build/
**/.gradle/
**/local.properties
**/*.iml
**/cxx/

# ─── IDE 配置 ───
/.idea/
**/.idea/
*.swp
*.swo
*~

# ─── macOS 系统文件 ───
.DS_Store
Thumbs.db

# ─── Flutter 模块 ───
flutter_module/build/
flutter_module/.dart_tool/
flutter_module/.packages
flutter_module/.pub-cache/
flutter_module/pubspec.lock
flutter_module/.flutter-plugins
flutter_module/.flutter-plugins-dependencies

# ─── Kotlin 编译缓存 ───
**/.kotlin/

# ─── APK 产物（太大不上传）───
**/*.apk
**/*.aab
**/*.ap_
**/*.dex

# ─── 日志 ───
*.log

# ─── WorkBuddy Skills 缓存（非项目特定，不追踪）───
**/.workbuddy/skills/

# ─── WorkBuddy 记忆文件属于项目上下文，需要进 Git ───
# .agent/ 和 .workbuddy/memory/ 不上传 gitignore
