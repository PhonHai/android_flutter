<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_comment.xml — 第 4 级：总结页
  【传统 Java 思维】
  导航链条终点，不是番茄钟。
  番茄钟在首页（MainActivity/HomeFragment），这里只展示完成状态。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅"
        android:textSize="64sp" />

    <TextView
        android:id="@+id/tv_summary_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="条目 X 已完成"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="导航演示结束"
        android:layout_marginTop="16dp"
        android:textColor="#888888" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="按返回键可逐级回溯查看返回栈效果"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btn_back_to_detail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="48dp"
        android:text="返回详情页 (popBackStack)" />

    <Button
        android:id="@+id/btn_back_to_home"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="回到首页 (pop to root)"
        android:backgroundTint="#008888" />

</LinearLayout>
